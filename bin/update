#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cat "$HOME/.system-tools-repo" 2>/dev/null || echo '')"
if [ -z "$REPO_DIR" ] || [ ! -d "$REPO_DIR" ]; then
    printf "Error: system-tools repository not found. Run 'install' first.\n" >&2
    exit 1
fi
# shellcheck source=/dev/null
source "$REPO_DIR/lib/common.sh"
# shellcheck source=/dev/null
source "$REPO_DIR/lib/config.sh"

ensure_sudo

printf "[APT] Updating..."
sudo apt update > /dev/null 2>&1
sudo apt upgrade -y > /dev/null 2>&1
sudo apt full-upgrade -y > /dev/null 2>&1
printf "\r%-20s\n" "[APT] Done"

printf "[SNAP] Updating..."
sudo snap refresh > /dev/null 2>&1
printf "\r%-20s\n" "[SNAP] Done"

if [ "$ENABLE_FIRMWARE_UPDATES" = true ]; then
    printf "[FW] Checking..."
    if command -v fwupdmgr >/dev/null 2>&1; then
        if fwupdmgr get-updates 2>/dev/null | grep -q "firmware updates available"; then
            printf "\r[FW] Updates available, updating...\n"
            sudo fwupdmgr update
            if fwupdmgr get-reboot-info 2>/dev/null | grep -q "yes"; then
                printf "[FW] Reboot required after firmware update\n"
            fi
        else
            printf "\r%-20s\n" "[FW] No updates"
        fi
    else
        printf "\r%-20s\n" "[FW] Unavailable"
    fi
fi
