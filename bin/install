#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/lib/config.sh"

CONFIG_FILE="$HOME/.system-tools-repo"

if [ ! -f "$CONFIG_FILE" ]; then
    printf "Error: Configuration file %s not found. Please run install.sh first.\n" "$CONFIG_FILE"
    exit 1
fi

REPO_DIR=$(cat "$CONFIG_FILE" | tr -d '\n')

if [ ! -d "$REPO_DIR" ]; then
    printf "Error: Repository directory %s does not exist.\n" "$REPO_DIR"
    exit 1
fi

cd "$REPO_DIR"

printf "Updating system-tools repository...\n"
git pull "$REPO_REMOTE" "$REPO_DEFAULT_BRANCH"

printf "Reinstalling tools...\n"

mkdir -p "$TARGET_INSTALL_DIR"

for script in update clean audit up full install monitor syshelp; do
    target="$TARGET_INSTALL_DIR/$script"
    if [ -L "$target" ] || { [ -e "$target" ] && [ "$(readlink -f "$target")" = "$(readlink -f "$REPO_DIR/bin/$script")" ]; }; then
        rm -f "$target"
    fi
    /usr/bin/install -m 755 "$REPO_DIR/bin/$script" "$target"
done

printf "System-tools updated successfully.\n"