#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cat "$HOME/.system-tools-repo" 2>/dev/null || echo '')"
if [ -z "$REPO_DIR" ] || [ ! -d "$REPO_DIR" ]; then
    printf "Error: system-tools repository not found. Run 'install' first.\n" >&2
    exit 1
fi
# shellcheck source=/dev/null
source "$REPO_DIR/lib/common.sh"
# shellcheck source=/dev/null
source "$REPO_DIR/lib/config.sh"

ensure_sudo

printf "[APT] Checking..."
sudo apt update > /dev/null 2>&1
apt_count=$(get_apt_upgradable)
printf "\r[APT] $(format_count "$apt_count" "package" "packages") upgradable\n"

printf "[SNAP] Checking..."
snap_count=$(get_snap_upgradable)
printf "\r[SNAP] $(format_count "$snap_count" "package" "packages") upgradable\n"

if [ "$ENABLE_FIRMWARE_UPDATES" = true ]; then
    printf "[FW] Checking..."
    if command -v fwupdmgr >/dev/null 2>&1; then
        if fwupdmgr get-updates 2>/dev/null | grep -q "firmware updates available"; then
            fw_count=$(fwupdmgr get-updates 2>/dev/null | grep -c "^•" || echo 0)
            printf "\r[FW] $(format_count "$fw_count" "firmware update" "firmware updates") available\n"
        else
            printf "\r[FW] No updates\n"
        fi
    else
        printf "\r[FW] Unavailable\n"
    fi
fi
