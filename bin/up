#!/usr/bin/env bash
set -euo pipefail

if ! sudo -n true 2>/dev/null; then
    sudo true
fi

printf "[APT] Checking..."
sudo apt update > /dev/null 2>&1
apt_count=$(
    apt list --upgradable 2>/dev/null \
    | tail -n +2 \
    | grep -c . || true
)

if [ "$apt_count" -eq 1 ]; then
    printf "\r[APT] 1 package upgradable\n"
else
    printf "\r[APT] %d packages upgradable\n" "$apt_count"
fi

printf "[SNAP] Checking..."
snap_count=$(
    snap refresh --list 2>/dev/null \
    | tail -n +2 \
    | grep -c . || true
)

if [ "$snap_count" -eq 1 ]; then
    printf "\r[SNAP] 1 package upgradable\n"
else
    printf "\r[SNAP] %d packages upgradable\n" "$snap_count"
fi

printf "[FW] Checking..."
if command -v fwupdmgr >/dev/null 2>&1; then
    if fwupdmgr get-updates 2>/dev/null | grep -q "firmware updates available"; then
        fw_count=$(fwupdmgr get-updates 2>/dev/null | grep -c "^•" || true)
        if [ "$fw_count" -eq 1 ]; then
            printf "\r[FW] 1 firmware update available\n"
        else
            printf "\r[FW] %d firmware updates available\n" "$fw_count"
        fi
    else
        printf "\r[FW] No updates\n"
    fi
else
    printf "\r[FW] Unavailable\n"
fi
