#!/usr/bin/env bash
set -euo pipefail

trap 'printf "\n[MONITOR] Stopped\n"; exit 0' INT

printf "=== SYSTEM MONITOR ===\n"
printf "Press Ctrl+C to stop\n\n"

# Initialize disk counters
disk_read_prev=0
disk_write_prev=0
while read -r _ _ _ _ _ _ _ _ _ _ _ _ _ reads _ writes _; do
    disk_read_prev=$((disk_read_prev + reads))
    disk_write_prev=$((disk_write_prev + writes))
done < /proc/diskstats
net_rx_prev=0
net_tx_prev=0
while read -r line; do
    [[ $line =~ ^[[:space:]]*$ ]] && continue
    [[ $line =~ Inter-\| ]] && continue
    [[ $line =~ face ]] && continue
    
    iface=$(echo "$line" | awk -F: '{print $1}' | sed 's/^[[:space:]]*//')
    [ "$iface" = "lo" ] && continue
    
    rx=$(echo "$line" | awk '{print $2}')
    tx=$(echo "$line" | awk '{print $10}')
    
    net_rx_prev=$((net_rx_prev + rx))
    net_tx_prev=$((net_tx_prev + tx))
done < /proc/net/dev

format_bytes() {
    local bytes=$1
    if [ $bytes -gt 1073741824 ]; then
        printf "%dGB/s" "$((bytes / 1073741824))"
    elif [ $bytes -gt 1048576 ]; then
        printf "%dMB/s" "$((bytes / 1048576))"
    elif [ $bytes -gt 1024 ]; then
        printf "%dKB/s" "$((bytes / 1024))"
    else
        printf "%dB/s" "$bytes"
    fi
}

while true; do
    printf "\033[2J\033[H"
    printf "=== SYSTEM MONITOR ===\n"
    printf "Time: %s\n\n" "$(date '+%H:%M:%S')"
    
    # CPU usage
    cpu_usage=$(top -bn1 | grep "Cpu(s)" | sed "s/.*, *\([0-9.]*\)%* id.*/\1/" | awk '{print 100 - $1}')
    printf "[CPU] Usage: %d%%\n" "${cpu_usage%.*}"
    
    # Memory usage  
    mem_info=$(free | awk 'NR==2{printf "%.0f %.0f %.0f", $3/1024, $2/1024, $3*100/$2}')
    read -r mem_used mem_total mem_percent <<< "$mem_info"
    printf "[MEM] Used: %dMB/%dMB (%d%%)\n" "$mem_used" "$mem_total" "$mem_percent"
    
    # Network I/O
    net_rx=0
    net_tx=0
    while read -r line; do
        [[ $line =~ ^[[:space:]]*$ ]] && continue
        [[ $line =~ Inter-\| ]] && continue
        [[ $line =~ face ]] && continue
        
        iface=$(echo "$line" | awk -F: '{print $1}' | sed 's/^[[:space:]]*//')
        [ "$iface" = "lo" ] && continue
        
        rx=$(echo "$line" | awk '{print $2}')
        tx=$(echo "$line" | awk '{print $10}')
        
        net_rx=$((net_rx + rx))
        net_tx=$((net_tx + tx))
    done < /proc/net/dev
    net_rx_rate=$(((net_rx - net_rx_prev) / 2))
    net_tx_rate=$(((net_tx - net_tx_prev) / 2))
    net_rx_prev=$net_rx
    net_tx_prev=$net_tx
    printf "[NET] RX: %s  TX: %s\n" "$(format_bytes "$net_rx_rate")" "$(format_bytes "$net_tx_rate")"
    
    # Disk I/O
    disk_read=0
    disk_write=0
    while read -r _ _ _ _ _ _ _ _ _ _ _ _ _ reads _ writes _; do
        disk_read=$((disk_read + reads))
        disk_write=$((disk_write + writes))
    done < /proc/diskstats
    disk_read_rate=$(((disk_read - disk_read_prev) * 512 / 2))
    disk_write_rate=$(((disk_write - disk_write_prev) * 512 / 2))
    disk_read_prev=$disk_read
    disk_write_prev=$disk_write
    printf "[DISK] Read: %s  Write: %s\n" "$(format_bytes "$disk_read_rate")" "$(format_bytes "$disk_write_rate")"
    
    sleep 2
done
