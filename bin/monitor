#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cat "$HOME/.system-tools-repo" 2>/dev/null || echo '')"
if [ -z "$REPO_DIR" ] || [ ! -d "$REPO_DIR" ]; then
    printf "Error: system-tools repository not found. Run 'install' first.\n" >&2
    exit 1
fi
# shellcheck source=/dev/null
source "$REPO_DIR/lib/common.sh"
# shellcheck source=/dev/null
source "$REPO_DIR/lib/config.sh"

trap 'printf "\n[MONITOR] Stopped\n"; exit 0' INT

printf "=== SYSTEM MONITOR ===\n"
printf "Press Ctrl+C to stop\n\n"

# Initialize disk I/O counters
read -r disk_read_prev disk_write_prev <<< "$(get_disk_io)"

# Initialize network I/O counters
read -r net_rx_prev net_tx_prev <<< "$(get_network_io)"

while true; do
    printf "\033[2J\033[H"
    printf "=== SYSTEM MONITOR ===\n"
    printf "Time: %s\n\n" "$(date '+%H:%M:%S')"
    
    # CPU usage
    cpu_usage=$(get_cpu_usage)
    printf "[CPU] Usage: %d%%\n" "${cpu_usage%.*}"
    
    # Memory usage  
    mem_info=$(free | awk 'NR==2{printf "%.0f %.0f %.0f", $3/1024, $2/1024, $3*100/$2}')
    read -r mem_used mem_total mem_percent <<< "$mem_info"
    printf "[MEM] Used: %dMB/%dMB (%d%%)\n" "$mem_used" "$mem_total" "$mem_percent"
    
    # Network I/O
    read -r net_rx net_tx <<< "$(get_network_io)"
    net_rx_rate=$(((net_rx - net_rx_prev) / MONITOR_REFRESH_INTERVAL))
    net_tx_rate=$(((net_tx - net_tx_prev) / MONITOR_REFRESH_INTERVAL))
    net_rx_prev=$net_rx
    net_tx_prev=$net_tx
    printf "[NET] RX: %s  TX: %s\n" "$(format_rate "$net_rx_rate")" "$(format_rate "$net_tx_rate")"
    
    # Disk I/O (sectors * 512 = bytes)
    read -r disk_read disk_write <<< "$(get_disk_io)"
    disk_read_rate=$(((disk_read - disk_read_prev) * 512 / MONITOR_REFRESH_INTERVAL))
    disk_write_rate=$(((disk_write - disk_write_prev) * 512 / MONITOR_REFRESH_INTERVAL))
    disk_read_prev=$disk_read
    disk_write_prev=$disk_write
    printf "[DISK] Read: %s  Write: %s\n" "$(format_rate "$disk_read_rate")" "$(format_rate "$disk_write_rate")"
    
    sleep "$MONITOR_REFRESH_INTERVAL"
done
