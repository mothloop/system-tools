#!/usr/bin/env bash
set -uo pipefail

REPO_DIR="$(cat "$HOME/.system-tools-repo" 2>/dev/null || echo '')"
if [ -z "$REPO_DIR" ] || [ ! -d "$REPO_DIR" ]; then
    printf "Error: system-tools repository not found. Run 'install' first.\n" >&2
    exit 1
fi
# shellcheck source=/dev/null
source "$REPO_DIR/lib/common.sh"
# shellcheck source=/dev/null
source "$REPO_DIR/lib/config.sh"

printf "=== SYSTEM AUDIT ===\n\n"

# DISK USAGE
printf "[DISK USAGE]\n"
df -h / | awk 'NR==2 {printf "  Root: %.1f%% used (%s/%s)\n", ($3/$2)*100, $3, $2}'
if [ -d "$HOME" ]; then
    home_usage=$(get_dir_size "$HOME")
    home_total=$(df "$HOME" 2>/dev/null | awk 'NR==2 {print $2"B"}' | numfmt --from=iec 2>/dev/null || echo "0")
    if [ "$home_total" -gt 0 ]; then
        home_percent=$(( (home_usage * 100) / home_total ))
        printf "  Home: %d%% used (%s/%s)\n" "$home_percent" "$(format_size "$home_usage")" "$(format_size "$home_total")"
    fi
fi
printf "\n"

# LARGE FILES
printf "[LARGE FILES]\n"
largest_files=$(find "$HOME" /var /tmp -type f -size +500M 2>/dev/null | head -5 || echo "")
if [ -n "$largest_files" ]; then
    echo "$largest_files" | while read -r file; do
        size=$(stat -c%s "$file" 2>/dev/null || echo 0)
        printf "  %s (%s)\n" "$(basename "$file")" "$(format_size "$size")"
    done
else
    printf "  No files larger than 500MB found\n"
fi
printf "\n"

# CACHE & TEMP - Get all sizes in one pass
printf "[CACHE & TEMP]\n"
cache_size=0
[ -d /var/cache ] && cache_size=$(du -sb /var/cache 2>/dev/null | awk '{print $1}')
user_cache=0
[ -d ~/.cache ] && user_cache=$(du -sb ~/.cache 2>/dev/null | awk '{print $1}')
tmp_size=0
[ -d /tmp ] && tmp_size=$(du -sb /tmp 2>/dev/null | awk '{print $1}')

printf "  /var/cache: %s\n" "$(format_size "$cache_size")"
printf "  ~/.cache: %s\n" "$(format_size "$user_cache")"
printf "  /tmp: %s\n" "$(format_size "$tmp_size")"
printf "\n"

# PACKAGES
printf "[PACKAGES]\n"
apt_count=$(get_apt_count)
snap_count=$(get_snap_count)
printf "  APT packages: %s\n" "$(format_count "$apt_count" "package" "packages")"
printf "  Snap packages: %s\n" "$(format_count "$snap_count" "package" "packages")"
printf "\n"

# FIRMWARE
printf "[FIRMWARE]\n"
if [ "$ENABLE_FIRMWARE_UPDATES" = true ]; then
    if command -v fwupdmgr >/dev/null 2>&1; then
        if fwupdmgr get-updates 2>/dev/null | grep -q "firmware updates available"; then
            fw_count=$(fwupdmgr get-updates 2>/dev/null | grep -c "^•" || echo 0)
            printf "  Updates available: %s\n" "$(format_count "$fw_count" "update" "updates")"
        else
            printf "  Status: Up to date\n"
        fi
    else
        printf "  Status: Tool unavailable\n"
    fi
else
    printf "  Status: Disabled\n"
fi
printf "\n"

# SYSTEM HEALTH
printf "[SYSTEM HEALTH]\n"
printf "  Uptime: %s\n" "$(get_uptime)"
printf "  Memory: %s%% used\n" "$(get_memory_usage)"
updates=$(get_apt_upgradable)
printf "  Pending updates: %s\n" "$(format_count "$updates" "update" "updates")"
orphaned=$(get_orphaned_packages)
printf "  Orphaned packages: %s\n" "$(format_count "$orphaned" "package" "packages")"
printf "\n"

# CLEANLINESS SCORE
printf "[CLEANLINESS SCORE]\n"
score=100

[ "$cache_size" -gt "$CACHE_WARN_THRESHOLD" ] && score=$((score - SCORE_CACHE_PENALTY))
[ "$user_cache" -gt "$USER_CACHE_WARN_THRESHOLD" ] && score=$((score - SCORE_USER_CACHE_PENALTY))
[ "$tmp_size" -gt "$TMP_WARN_THRESHOLD" ] && score=$((score - SCORE_TMP_PENALTY))
[ "$orphaned" -gt 0 ] && score=$((score - SCORE_ORPHANED_PENALTY))
[ "$updates" -gt "$SCORE_UPDATE_THRESHOLD" ] && score=$((score - SCORE_UPDATES_PENALTY))

if [ "$score" -ge "$SCORE_EXCELLENT" ]; then
    status="EXCELLENT"
elif [ "$score" -ge "$SCORE_GOOD" ]; then
    status="GOOD"
elif [ "$score" -ge "$SCORE_FAIR" ]; then
    status="FAIR"
else
    status="POOR"
fi

printf "  Score: %d/100 (%s)\n" "$score" "$status"
