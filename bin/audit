#!/usr/bin/env bash
set -uo pipefail

format_size() {
    numfmt --to=iec-i --suffix=B "$1" 2>/dev/null || echo "$1B"
}

printf "=== SYSTEM AUDIT ===\n\n"

printf "[DISK USAGE]\n"
df -h / | awk 'NR==2 {printf "  Root: %.1f%% used (%s/%s)\n", ($3/$2)*100, $3, $2}'
if [ -d "$HOME" ]; then
    home_usage=$(du -sb "$HOME" 2>/dev/null | awk '{print $1}' || echo 0)
    home_total=$(df "$HOME" 2>/dev/null | awk 'NR==2 {print $2"B"}' | numfmt --from=iec 2>/dev/null || echo "0")
    if [ "$home_total" -gt 0 ]; then
        printf "  Home: %.1f%% used (%s/%s)\n" $(( (home_usage * 100) / home_total )) "$(format_size "$home_usage")" "$(format_size "$home_total")"
    fi
fi
printf "\n"

printf "[LARGE FILES]\n"
largest_files=$(find "$HOME" /var /tmp -type f -size +500M 2>/dev/null | head -5 || echo "")
if [ -n "$largest_files" ]; then
    echo "$largest_files" | while read -r file; do
        size=$(stat -c%s "$file" 2>/dev/null || echo 0)
        printf "  %s (%s)\n" "$(basename "$file")" "$(format_size "$size")"
    done
else
    printf "  No files larger than 500MB found\n"
fi
printf "\n"

printf "[CACHE & TEMP]\n"
cache_size=0
user_cache=0
tmp_size=0

if [ -d /var/cache ]; then
    cache_size=$(du -sb /var/cache 2>/dev/null | awk '{print $1}')
    [ -z "$cache_size" ] && cache_size=0
    printf "  /var/cache: %s\n" "$(format_size "$cache_size")"
fi
if [ -d ~/.cache ]; then
    user_cache=$(du -sb ~/.cache 2>/dev/null | awk '{print $1}')
    [ -z "$user_cache" ] && user_cache=0
    printf "  ~/.cache: %s\n" "$(format_size "$user_cache")"
fi
if [ -d /tmp ]; then
    tmp_size=$(du -sb /tmp 2>/dev/null | awk '{print $1}')
    [ -z "$tmp_size" ] && tmp_size=0
    printf "  /tmp: %s\n" "$(format_size "$tmp_size")"
fi
printf "\n"

printf "[PACKAGES]\n"
apt_count=$(dpkg -l 2>/dev/null | grep -c "^ii" || echo 0)
snap_count=$(snap list 2>/dev/null | tail -n +2 | grep -c . || echo 0)
printf "  APT packages: %d\n" "$apt_count"
printf "  Snap packages: %d\n" "$snap_count"
printf "\n"

printf "[SYSTEM HEALTH]\n"
uptime_output=$(uptime -p 2>/dev/null || uptime | sed 's/.*up //' | sed 's/,.*$//')
printf "  Uptime: %s\n" "$uptime_output"

mem_info=$(free -b 2>/dev/null | awk 'NR==2 {printf "%.1f%%", ($3/$2)*100}' || echo "N/A")
printf "  Memory: %s used\n" "$mem_info"

updates=$(apt list --upgradable 2>/dev/null | tail -n +2 | wc -l | tr -d ' ')
[ -z "$updates" ] && updates=0
printf "  Pending updates: %d\n" "$updates"

orphaned=$(apt autoremove -s 2>/dev/null | grep "^Remov" | wc -l | tr -d ' ')
[ -z "$orphaned" ] && orphaned=0
printf "  Orphaned packages: %d\n" "$orphaned"
printf "\n"

printf "[CLEANLINESS SCORE]\n"
score=100
[ "$cache_size" -gt 1073741824 ] && score=$((score - 10)) || true
[ "$user_cache" -gt 3221225472 ] && score=$((score - 15)) || true
[ "$tmp_size" -gt 1073741824 ] && score=$((score - 10)) || true
[ "$orphaned" -gt 0 ] && score=$((score - 5)) || true
[ "$updates" -gt 5 ] && score=$((score - 10)) || true

if [ "$score" -ge 85 ]; then
    status="EXCELLENT"
elif [ "$score" -ge 70 ]; then
    status="GOOD"
elif [ "$score" -ge 50 ]; then
    status="FAIR"
else
    status="POOR"
fi

printf "  Score: %d/100 (%s)\n" "$score" "$status"
